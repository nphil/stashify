# Python
__pycache__/
*.pyc

# local model/data mounts (never commit media or weights)
models/
data/
*.pth

# secrets & host-local overrides (never commit)
.env
docker-compose.override.yml

# Windows runner runtime (venv/config/service live in %LOCALAPPDATA%, not the repo)
winrunner/.venv/
winrunner/tmp/
winrunner/*.local.json
